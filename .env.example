# Copy to .env (or just export these) before running the demo.

# REQUIRED: a FUNDED Anthropic API key (the demo makes real model calls).
# Note: a Claude Code subscription token is NOT a billable API key — you need
# an api.anthropic.com key with credit balance.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
BAKEOFF_MODEL=claude-sonnet-4-6          # or claude-haiku-4-5-20251001 (cheaper), claude-opus-4-8
TIEFSTOCKS_URL=http://127.0.0.1:8001     # the live API under test
